#!/usr/bin/env bash
# Pre-push hook: run the full test suite and version-bump check before pushing.
set -euo pipefail

REMOTE="$1"
REMOTE_URL="$2"

echo "--- pre-push: pytest ---"
if ! python -m pytest; then
    echo ""
    echo "Tests failed. Push aborted."
    exit 1
fi

echo "--- pre-push: version bump check ---"
if ! bash scripts/check_version_bump.sh; then
    exit 1
fi

echo "pre-push checks passed."
